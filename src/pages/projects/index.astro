---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Projects" description="My projects" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<ul class="project-list">
				{projects.map((project) => (
					<li>
						<div class="card">
							{project.data.heroImage && (
								<img src={project.data.heroImage.src} alt={project.data.title} class="project-image" />
							)}
							<div class="card-body">
								<div class="card-top">
									<a href={`/projects/${project.id}/`} class="project-title">
										{project.data.title}
									</a>
									<div class="card-links">
										{project.data.githubUrl && (
											<a href={project.data.githubUrl} target="_blank" rel="noopener" class="link-btn">
												<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
													<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
												</svg>
												GitHub
											</a>
										)}
										{project.data.liveUrl && (
											<a href={project.data.liveUrl} target="_blank" rel="noopener" class="link-btn live">
												<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
													<path fill="currentColor" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5z"/>
													<path fill="currentColor" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0v-5z"/>
												</svg>
												Live
											</a>
										)}
									</div>
								</div>
								<p class="project-desc">{project.data.description}</p>
								{project.data.tags && project.data.tags.length > 0 && (
									<div class="tags">
										{project.data.tags.map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
						</div>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 2rem;
	}

	.project-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.card {
		border: 1px solid var(--border);
		border-radius: 10px;
		overflow: hidden;
		transition: border-color 0.15s ease, box-shadow 0.15s ease;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.card:hover {
		border-color: var(--accent);
		box-shadow: var(--shadow-md);
	}

	.project-image {
		width: 100%;
		height: 180px;
		object-fit: cover;
		border-radius: 0;
	}

	.card-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		flex: 1;
	}

	.card-top {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.project-title {
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--text);
		text-decoration: none;
		line-height: 1.3;
	}

	.project-title:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.card-links {
		display: flex;
		gap: 0.5rem;
		flex-shrink: 0;
	}

	.link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.78rem;
		font-weight: 500;
		padding: 0.25rem 0.6rem;
		border-radius: 5px;
		border: 1px solid var(--border);
		color: var(--text-muted);
		text-decoration: none;
		transition: all 0.15s ease;
		white-space: nowrap;
	}

	.link-btn:hover {
		border-color: var(--text-muted);
		color: var(--text);
		text-decoration: none;
	}

	.link-btn.live {
		border-color: var(--accent);
		color: var(--accent);
	}

	.link-btn.live:hover {
		background: var(--accent);
		color: white;
	}

	.project-desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: auto;
	}

	.tag {
		font-size: 0.75rem;
		font-weight: 500;
		padding: 0.2rem 0.55rem;
		border-radius: 4px;
		background: var(--bg-secondary);
		color: var(--text-muted);
		border: 1px solid var(--border);
	}

	@media (max-width: 720px) {
		.project-list {
			grid-template-columns: 1fr;
		}
	}
</style>