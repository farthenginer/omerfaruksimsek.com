---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Ömer Faruk Şimşek" description="Game developer & software enthusiast from Malatya, Turkey." />
	</head>
	<body>
		<Header />
		<main>
			<!-- INTRO -->
			<section class="intro">
				<span class="eyebrow">About Me</span>
				<h1>I've been building since I was 12.</h1>
				<p class="lead">
					I'm Ömer, 18, from Malatya, Turkey. No formal education in CS, no fancy setup growing up —
					just a 2009 laptop, Unity, and an obsession with making things work.
				</p>
			</section>

			<!-- STORY -->
			<section class="section">
				<h2>The Story</h2>
				<p>
					When I was 10, my math teacher noticed I had a natural feel for computers — even though I'd
					barely touched one. He told me to learn software. I tried on my sister's tablet, but it
					wasn't possible. Two years later, I got my hands on a 2009 laptop. It couldn't run games,
					so I decided to <strong>build my own.</strong>
				</p>
				<p>
					I installed one of the first versions of Unity and started making games. I was staying up
					until late every night. It consumed me completely — in the best way. By 14, I realized I
					could sell what I made. Using my mother's freelance account, I started delivering projects.
					Over the next few years, I completed <strong>50+ successful orders</strong> — first doing
					university students' assignments, then building real commercial products.
				</p>
				<p>
					All of this while having <strong>no internet or computer at home.</strong> I worked wherever
					I could find a connection.
				</p>
			</section>

			<!-- TIMELINE -->
			<section class="section">
				<h2>Timeline</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="timeline-year">2020</span>
						<div class="timeline-content">
							<h3>First Unity project</h3>
							<p>Got a 2009 laptop. Installed Unity. Started building games from scratch, self-taught, no tutorials in Turkish back then. I was 12.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2022</span>
						<div class="timeline-content">
							<h3>Started freelancing at 14</h3>
							<p>Used my mother's account on a local platform. Started with university students' game assignments, grew from there.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2022</span>
						<div class="timeline-content">
							<h3>TÜBİTAK 2204-A — first attempt</h3>
							<p>Applied to the national science competition. Eliminated in the preliminary round. Kept going.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2023</span>
						<div class="timeline-content">
							<h3>Social impact games</h3>
							<p>Built an earthquake awareness game after the February 6th Malatya earthquake. Also developed an environmental awareness game and a traffic safety game for my school club.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2024</span>
						<div class="timeline-content">
							<h3>Sweet TTCoin & TÜBİTAK Ankara Final</h3>
							<p>Shipped a crypto mobile game that hit <strong>tens of thousands of downloads</strong> on the app store. Also reached the Ankara final of TÜBİTAK 2204-A with "Tarihin Sanal Yüzü" — a Firebase + Photon multiplayer history game. Finished 11th nationally.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2025</span>
						<div class="timeline-content">
							<h3>Magara Jam & Cloth AI</h3>
							<p>Attended Magara Jam 2025 in Istanbul physically. Currently building <strong>Cloth AI</strong> — an AI-powered fashion app with FlutterFlow. Targeting launch soon.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- SKILLS -->
			<section class="section">
				<h2>Tech Stack</h2>
				<div class="skills">
					<div class="skill-group">
						<span class="skill-label">Primary</span>
						<div class="skill-tags">
							<span class="tag">Unity</span>
							<span class="tag">C#</span>
							<span class="tag">FlutterFlow</span>
						</div>
					</div>
					<div class="skill-group">
						<span class="skill-label">Backend & Tools</span>
						<div class="skill-tags">
							<span class="tag">Firebase</span>
							<span class="tag">Photon Network</span>
							<span class="tag">Git</span>
						</div>
					</div>
					<div class="skill-group">
						<span class="skill-label">Platforms</span>
						<div class="skill-tags">
							<span class="tag">Android / Play Store</span>
							<span class="tag">iOS</span>
							<span class="tag">PC</span>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="cta">
				<p>Want to work together or just say hi?</p>
				<a href="mailto:info@omerfaruksimsek.com" class="btn-primary">Get in touch →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		padding: 3rem 0 2.5rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 3rem;
	}

	.eyebrow {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
	}

	.intro h1 {
		font-size: 2.5rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0.5rem 0 1rem;
		line-height: 1.15;
	}

	.lead {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 560px;
		line-height: 1.7;
		margin: 0;
	}

	.section {
		margin-bottom: 3rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--border);
	}

	.section h2 {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}

	.section p {
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text);
		max-width: 620px;
	}

	/* TIMELINE */
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 80px 1fr;
		gap: 1.5rem;
		padding: 1.25rem 0;
		border-bottom: 1px solid var(--border);
	}

	.timeline-item:last-child {
		border-bottom: none;
	}

	.timeline-year {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--accent);
		padding-top: 0.2rem;
		letter-spacing: 0.02em;
	}

	.timeline-content h3 {
		font-size: 1rem;
		font-weight: 600;
		margin: 0 0 0.4rem;
	}

	.timeline-content p {
		font-size: 0.9rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.6;
		max-width: none;
	}

	/* SKILLS */
	.skills {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.skill-group {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 1rem;
		align-items: center;
	}

	.skill-label {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.8rem;
		font-weight: 500;
		padding: 0.25rem 0.65rem;
		border-radius: 5px;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		color: var(--text);
	}

	/* CTA */
	.cta {
		padding: 2rem 0 1rem;
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.cta p {
		margin: 0;
		color: var(--text-muted);
		font-size: 1rem;
	}

	.btn-primary {
		display: inline-block;
		padding: 0.6rem 1.25rem;
		background: var(--text);
		color: var(--bg);
		border-radius: 7px;
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		transition: opacity 0.15s ease;
		white-space: nowrap;
	}

	.btn-primary:hover {
		opacity: 0.85;
		text-decoration: none;
		color: var(--bg);
	}

	@media (max-width: 720px) {
		.intro h1 { font-size: 1.9rem; }
		.timeline-item { grid-template-columns: 60px 1fr; gap: 1rem; }
		.skill-group { grid-template-columns: 1fr; gap: 0.5rem; }
		.cta { flex-direction: column; align-items: flex-start; }
	}
</style>